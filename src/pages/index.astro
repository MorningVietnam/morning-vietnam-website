<script>
  // ── Crew tooltip ───────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.hp-crew__avatar').forEach(avatar => {
    avatar.addEventListener('click', () => {
      const tip = avatar.querySelector<HTMLElement>('.hp-crew__tooltip');
      if (!tip) return;
      tip.classList.add('is-visible');
      setTimeout(() => tip.classList.remove('is-visible'), 1500);
    });
  });

  // ── Hero brand parallax ────────────────────────────────────────
  const brandText = document.getElementById('hp-brand-text') as HTMLElement | null;
  if (brandText && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    window.addEventListener('scroll', () => {
      const y = window.scrollY * -0.4;
      brandText.style.transform = `translateY(${y}px)`;
    }, { passive: true });
  }

  // ── Showcase 2-col slider ──────────────────────────────────────
  const showcase = document.querySelector('.hp-showcase2') as HTMLElement | null;
  const showcaseDataEl = document.getElementById('showcase-data');
  if (showcase && showcaseDataEl) {
    const data = JSON.parse(showcaseDataEl.textContent ?? '[]');
    const dots = document.querySelectorAll<HTMLButtonElement>('.hp-showcase2__dot');
    const nextBtn = document.getElementById('showcase-next');

    const els = {
      heading:  document.getElementById('showcase-heading'),
      image:    document.getElementById('showcase-image') as HTMLImageElement | null,
      current:  document.getElementById('showcase-current'),
      desc:     document.getElementById('showcase-desc'),
      duration: document.getElementById('showcase-duration'),
      lang:     document.getElementById('showcase-lang'),
      link:     document.getElementById('showcase-link') as HTMLAnchorElement | null,
    };

    let idx = 0;
    let timer: ReturnType<typeof setInterval>;

    function update(newIdx: number) {
      if (newIdx === idx) return;
      showcase!.classList.add('fading');
      setTimeout(() => {
        idx = ((newIdx % data.length) + data.length) % data.length;
        const t = data[idx];
        if (els.heading)  els.heading.textContent  = t.name;
        if (els.image)  { els.image.src = t.image; els.image.alt = t.name; }
        if (els.current)  els.current.textContent  = String(idx + 1).padStart(2, '0');
        if (els.desc)     els.desc.textContent      = (t.description?.slice(0, 220) ?? t.tagline);
        if (els.duration) els.duration.textContent  = t.duration.join(' / ');
        if (els.lang)     els.lang.textContent      = t.languages.join(' · ');
        if (els.link)     els.link.href             = `/tours/${t.slug}`;
        dots.forEach((d, i) => d.classList.toggle('active', i === idx));
        showcase!.classList.remove('fading');
      }, 400);
    }

    dots.forEach(d => d.addEventListener('click', () => {
      clearInterval(timer);
      update(parseInt(d.dataset.idx ?? '0'));
      startTimer();
    }));

    nextBtn?.addEventListener('click', () => {
      clearInterval(timer);
      update(idx + 1);
      startTimer();
    });

    function startTimer() {
      timer = setInterval(() => update(idx + 1), 6000);
    }

    showcase.addEventListener('mouseenter', () => clearInterval(timer));
    showcase.addEventListener('mouseleave', startTimer);
    startTimer();
  }

  // ── Testimonials full-bleed slider ─────────────────────────────
  const testi = document.querySelector('.hp-testi');
  if (testi) {
    const slides = testi.querySelectorAll<HTMLElement>('.hp-testi__slide');
    const tdots  = testi.querySelectorAll<HTMLButtonElement>('.hp-testi__dot');
    let tIdx = 0;
    let tTimer: ReturnType<typeof setInterval>;

    function goTesti(n: number) {
      tIdx = ((n % slides.length) + slides.length) % slides.length;
      slides.forEach((s, i) => s.classList.toggle('active', i === tIdx));
      tdots.forEach((d, i)  => d.classList.toggle('active', i === tIdx));
    }

    tdots.forEach(d => d.addEventListener('click', () => {
      clearInterval(tTimer);
      goTesti(parseInt(d.dataset.target ?? '0'));
      startTesti();
    }));

    function startTesti() {
      tTimer = setInterval(() => goTesti(tIdx + 1), 6000);
    }

    testi.addEventListener('mouseenter', () => clearInterval(tTimer));
    testi.addEventListener('mouseleave', startTesti);
    startTesti();
  }
</script>
