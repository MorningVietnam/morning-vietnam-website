---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NotifyPopup from '../../components/NotifyPopup.astro';
import { tours } from '../../data/tours.ts';

export function getStaticPaths() {
  return tours.map(tour => ({ params: { slug: tour.slug }, props: { tour } }));
}

const { tour } = Astro.props;

if (tour.comingSoon) {
  return Astro.redirect('/tours');
}

const galleryItems = tour.gallery && tour.gallery.length > 0
  ? tour.gallery
  : [{ src: tour.image, alt: tour.name }];

const hasDurationOptions = tour.durationOptions && tour.durationOptions.length > 1;

const pitch = tour.pitch;
const hasDurationPitch = pitch && typeof pitch === 'object' && !('headline' in (pitch as any)) && !Array.isArray(pitch);
const firstDurKey: string = (tour.durationOptions as any)?.[0]?.id || '1day';
const pitchDefault: any = hasDurationPitch
  ? ((pitch as any)[firstDurKey] ?? Object.values(pitch as any)[0])
  : pitch;

const hasDurationValue = tour.valueAnchor && typeof tour.valueAnchor === 'object' && !('headline' in (tour.valueAnchor as any));
const valueAnchorObj: any = hasDurationValue
  ? ((tour.valueAnchor as any)[firstDurKey] ?? Object.values(tour.valueAnchor as any)[0])
  : tour.valueAnchor;
const valueAnchor: any = valueAnchorObj?.headline ? valueAnchorObj : null;

const overview     = tour.storytelling;
const elevation    = tour.elevationProfile;
const elevMax: number = (tour as any).elevationMax ?? 1500;
const activityCards = tour.activityCards;
const welcomePack  = tour.welcomePack;
const unlock       = tour.unlockChallenge;
const season       = tour.seasonality;
const faqs         = tour.faqs;

const tripInfoData   = (tour.tripInfo as any) || null;
const hasTripInfo    = !!tripInfoData;
const defaultTripKey = (tour.durationOptions as any)?.[0]?.id || 'default';
const defaultTripItems: any[] = hasTripInfo
  ? (tripInfoData[defaultTripKey] || tripInfoData['default'] || [])
  : [];
---

<BaseLayout title={tour.name} description={tour.tagline}>

  <!-- ═══ S1 · b-product (split hero) ════════════════════════════ -->
  <section class="td-product page-offset">
    <div class="td-product__inner">

      <!-- Left: Image gallery -->
      <div class="td-product__gallery">
        {tour.gallery && tour.gallery.length > 0 ? (
          <>
            <div class="td-product__main-image">
              <img id="td-main-img" src={galleryItems[0].src} alt={galleryItems[0].alt} fetchpriority="high" />
              {galleryItems.length > 1 && (
                <div class="td-gallery__nav">
                  <button id="td-prev" class="td-gallery__arrow" aria-label="Previous image">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                      <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                  <button id="td-next" class="td-gallery__arrow" aria-label="Next image">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                      <path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                </div>
              )}
            </div>
            <div class="td-product__thumbs">
              {galleryItems.map((g, i) => (
                <button
                  class={`td-product__thumb${i === 0 ? ' active' : ''}`}
                  data-src={g.src}
                  data-alt={g.alt}
                  aria-label={`Image ${i + 1}`}
                >
                  <img src={g.src} alt={g.alt} loading="lazy" />
                </button>
              ))}
            </div>
          </>
        ) : (
          <div class="td-product__photo-pending">
            <div class="td-product__photo-pending-icon">📷</div>
            <strong>PHOTO PENDING</strong>
            <p>Hero gallery for {tour.name}. Brief: 4–6 wide shots showing the route, activities, and people. Candid moments preferred over posed.</p>
          </div>
        )}
      </div>

      <!-- Right: Purchase panel -->
      <div class="td-product__panel" id="td-product-panel" data-duration-options={hasDurationOptions ? JSON.stringify(tour.durationOptions) : ''}>
        <p class="td-product__eyebrow">
          {tour.region === 'north' ? 'North Vietnam' : tour.region === 'soon' ? 'Coming soon' : tour.region}
          &nbsp;·&nbsp;{tour.duration.join(' / ')}
        </p>
        <h1 class="td-product__heading">{tour.name}</h1>

        {hasDurationOptions ? (
          <>
            <!-- Duration toggle buttons -->
            <div class="td-duration__tabs" id="td-duration-tabs">
              {tour.durationOptions.map((opt: {id: string; label: string}, i: number) => (
                <button
                  class={`td-duration__tab${i === 0 ? ' is-active' : ''}`}
                  data-duration={opt.id}
                  type="button"
                >
                  {opt.label}
                </button>
              ))}
            </div>

            <!-- Dynamic price -->
            {tour.durationOptions[0].price != null && (
              <div class="td-product__price" id="td-price-display">
                <span id="td-price-amount">${tour.durationOptions[0].price}</span>
                <span class="td-product__price-unit">/person</span>
              </div>
            )}

            <!-- Dynamic tagline -->
            <p class="td-product__tagline" id="td-tagline-display">{tour.durationOptions[0].tagline}</p>

            {!tour.comingSoon ? (
              <div class="td-product__cta" id="td-cta-display">
                <a
                  href={`https://wa.me/84961836611?text=${encodeURIComponent(tour.durationOptions[0].waText)}`}
                  target="_blank"
                  rel="noopener"
                  class="c-button c-button--primary td-product__book"
                  id="td-cta-btn"
                >
                  {tour.durationOptions[0].ctaLabel}
                </a>
                <p class="td-product__cta-note" id="td-cta-note">{tour.durationOptions[0].ctaNote}</p>
              </div>
            ) : (
              <div class="td-product__cta">
                <button class="c-button c-button--outline" data-popup-trigger="#notify-popup">
                  Notify me when live
                </button>
                <p class="td-product__cta-note">{tour.price}</p>
              </div>
            )}

            <!-- Trip Info cards -->
            {hasTripInfo && (
              <div class="td-tripinfo" id="td-tripinfo-section"
                data-trip-info={JSON.stringify(tripInfoData)}>
                <p class="td-tripinfo__section-label">Trip info</p>
                <div class="td-tripinfo__grid" id="td-tripinfo-grid">
                  {defaultTripItems.map((item: any) => (
                    <div class="td-tripinfo__card">
                      <div class="td-tripinfo__icon-wrap">
                        <i class={`ti ti-${item.icon}`} aria-hidden="true"></i>
                      </div>
                      <div>
                        <p class="td-tripinfo__label">{item.label}</p>
                        <p class="td-tripinfo__value">{item.value}</p>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </>
        ) : (
          <>
            <div class="td-product__price">
              {tour.priceUSD ? `$${tour.priceUSD}` : 'TBA'}
              <span class="td-product__price-unit">/person</span>
            </div>
            <p class="td-product__tagline">{tour.tagline}</p>

            {!tour.comingSoon ? (
              <div class="td-product__cta">
                <a
                  href={`https://wa.me/84961836611?text=Hi%20Morning%20Vietnam%20-%20I'd%20like%20to%20book%20${encodeURIComponent(tour.name)}`}
                  target="_blank"
                  rel="noopener"
                  class="c-button c-button--primary td-product__book"
                >
                  Reserve my spot →
                </a>
                <p class="td-product__cta-note">No payment now. We hold your spot, you pay 14 days before. Free cancellation.</p>
              </div>
            ) : (
              <div class="td-product__cta">
                <button class="c-button c-button--outline" data-popup-trigger="#notify-popup">
                  Notify me when live
                </button>
                <p class="td-product__cta-note">{tour.price}</p>
              </div>
            )}

            <!-- Trip Info cards (single-duration tours) -->
            {hasTripInfo && (
              <div class="td-tripinfo" id="td-tripinfo-section">
                <p class="td-tripinfo__section-label">Trip info</p>
                <div class="td-tripinfo__grid" id="td-tripinfo-grid">
                  {defaultTripItems.map((item: any) => (
                    <div class="td-tripinfo__card">
                      <div class="td-tripinfo__icon-wrap">
                        <i class={`ti ti-${item.icon}`} aria-hidden="true"></i>
                      </div>
                      <div>
                        <p class="td-tripinfo__label">{item.label}</p>
                        <p class="td-tripinfo__value">{item.value}</p>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </>
        )}
      </div>
    </div>
  </section>

  <!-- ═══ S2 · b-marquee ═════════════════════════════════════════ -->
  <div class="b-marquee td-marquee" aria-hidden="true">
    <div class="b-marquee__track">
      {[...Array(2)].map(() => (
        <>
          <span class="b-marquee__item">All meals included<span class="b-marquee__sep">✦</span></span>
          <span class="b-marquee__item">Licensed int'l operator<span class="b-marquee__sep">✦</span></span>
          <span class="b-marquee__item">No payment upfront<span class="b-marquee__sep">✦</span></span>
          <span class="b-marquee__item">Free cancellation<span class="b-marquee__sep">✦</span></span>
          <span class="b-marquee__item">Unlock Challenge included<span class="b-marquee__sep">✦</span></span>
        </>
      ))}
    </div>
  </div>

  <!-- ═══ S3 · b-pitch (Hook storytelling) ═══════════════════════ -->
  <section class="td-pitch" id="td-pitch-section" data-pitch={hasDurationPitch ? JSON.stringify(tour.pitch) : ''}>
    <div class="td-pitch__inner">
      <p class="section-label">The pitch</p>
      <blockquote class="td-pitch__headline" id="td-pitch-headline">
        {pitchDefault?.headline || "By tonight, you'll have done things most weekenders never get to."}
      </blockquote>
      <div class="td-pitch__body">
        {(pitchDefault?.paragraphs || []).map((p: string) => <p>{p}</p>)}
        <p class="td-pitch__closing" id="td-pitch-closing">{pitchDefault?.closingLine || ''}</p>
      </div>
      <ul class="td-pitch__bullets" id="td-pitch-bullets">
        {(pitchDefault?.bullets || []).map((b: string) => <li>{b}</li>)}
      </ul>
    </div>
  </section>

  <!-- ═══ S4 · b-value (Justify the price) ═══════════════════════ -->
  {valueAnchor && (
    <section class="td-value" id="td-value-section" data-value-anchor={hasDurationValue ? JSON.stringify(tour.valueAnchor) : ''}>
      <div class="td-value__inner">
        <div class="td-value__left">
          <p class="section-label">Worth it?</p>
          <h2 class="td-value__heading" id="td-value-headline">{valueAnchor.headline}</h2>
          <div class="td-value__body" id="td-value-paragraphs">
            {(valueAnchor.paragraphs || []).map((p: string) => <p>{p}</p>)}
          </div>
        </div>
        <div class="td-value__right">
          <table class="td-value__table">
            <thead>
              <tr>
                <th></th>
                <th class="td-value__th-typical">Typical tour</th>
                <th class="td-value__th-us">Morning Vietnam</th>
              </tr>
            </thead>
            <tbody>
              {(valueAnchor.compareTable || []).map((row: {metric: string; typical: string; us: string}) => (
                <tr>
                  <td class="td-value__metric">{row.metric}</td>
                  <td class="td-value__bad">{row.typical}</td>
                  <td class="td-value__good">{row.us}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  )}

  <!-- ═══ S5 · b-overview ════════════════════════════════════════ -->
  <section class="td-overview">
    <div class="td-overview__inner">
      <div class="td-overview__left">
        <p class="section-label">About this tour</p>
        <h2 class="td-overview__headline">{overview?.headline || tour.tagline}</h2>
        <div class="td-overview__body">
          {(overview?.paragraphs?.length ? overview.paragraphs : [tour.description]).map((p: string | undefined) => p ? <p>{p}</p> : null)}
        </div>
      </div>
      <div class="td-overview__right">
        {overview?.pullImage ? (
          <img src={overview.pullImage} alt={tour.name} loading="lazy" />
        ) : (
          <div class="td-overview__photo-pending">
            <strong>PHOTO PENDING</strong>
            <p>Wide environmental shot for {tour.name} — landscape or activity moment, vertical orientation preferred (3:4 or 4:5).</p>
          </div>
        )}
      </div>
    </div>

  </section>

  <!-- ═══ S4 · b-timeline (SVG elevation chart) ═════════════════ -->
  <section class="td-timeline">
    <div class="td-timeline__inner">
      <p class="section-label">The journey</p>
      <h2 class="td-timeline__heading">A day, mapped.</h2>
      <p class="td-timeline__sub">Time across, elevation up. Every spike is a moment worth remembering.</p>

      {elevation && elevation.length > 0 ? (
        <div class="td-timeline__chart-wrap">
          <svg
            class="td-timeline__svg"
            viewBox="0 0 1200 450"
            preserveAspectRatio="xMidYMid meet"
            role="img"
            aria-label={`Elevation timeline for ${tour.name}`}
          >
            <defs>
              <linearGradient id="elevationGradient" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="var(--color-java)" stop-opacity="0.6" />
                <stop offset="100%" stop-color="var(--color-java)" stop-opacity="0" />
              </linearGradient>
            </defs>

            {/* Y-axis gridlines + labels — scale to elevMax */}
            {Array.from({ length: Math.floor(elevMax / 300) + 1 }, (_, i) => i * 300).map((elev) => {
              const yPos = 340 - (elev / elevMax) * 280;
              return (
                <>
                  <line x1="60" y1={yPos} x2="1160" y2={yPos} stroke="rgba(4,51,65,0.08)" stroke-width="1" />
                  <text x="50" y={yPos + 4} text-anchor="end" font-size="11" fill="rgba(4,51,65,0.5)" font-family="Commissioner, sans-serif">{elev}m</text>
                </>
              );
            })}

            {/* Paths: per-duration, built generically from durationOnly field */}
            {(() => {
              const allPts = elevation!;
              const sharedPts = allPts.filter((p: any) => !p.durationOnly);
              const pts1day = [...sharedPts, ...allPts.filter((p: any) => p.durationOnly === '1day')];
              const pts2d1n = [...sharedPts, ...allPts.filter((p: any) => p.durationOnly === '2d1n')];
              const pts3d2n = [...sharedPts, ...allPts.filter((p: any) => p.durationOnly === '3d2n')];

              function makePath(pts: any[], close: boolean) {
                const step = 1100 / Math.max(1, pts.length - 1);
                let d = pts.map((p: any, i: number) => {
                  const x = 60 + i * step;
                  const y = 340 - (p.elevation / elevMax) * 280;
                  return `${i === 0 ? 'M' : 'L'} ${x} ${y}`;
                }).join(' ');
                if (close) {
                  const lastX = 60 + (pts.length - 1) * step;
                  d += ` L ${lastX} 340 L 60 340 Z`;
                }
                return d;
              }

              const step1day = 1100 / Math.max(1, pts1day.length - 1);
              const step2d1n = 1100 / Math.max(1, pts2d1n.length - 1);
              const step3d2n = 1100 / Math.max(1, pts3d2n.length - 1);

              function renderDots(pts: any[], durClass: string, step: number) {
                return pts.map((p: any, i: number) => {
                  const x = 60 + i * step;
                  const y = 340 - (p.elevation / elevMax) * 280;
                  return (
                    <g class={`td-timeline__point ${durClass}${p.highlight ? ' is-highlight' : ''}`} data-duration={p.durationOnly || 'all'}>
                      <circle cx={x} cy={y} r={p.highlight ? 12 : 8} fill={p.highlight ? 'var(--color-sorbus)' : 'var(--color-java)'} stroke="white" stroke-width="3" />
                      <text x={x} y={y - 22} text-anchor="middle" font-size="11" font-weight="700" fill="var(--color-nordic)" font-family="Commissioner, sans-serif">{p.time}</text>
                      {(() => {
                        const label = p.label as string;
                        let line1 = label;
                        let line2 = '';
                        if (label.includes(' · ')) {
                          const idx = label.indexOf(' · ');
                          line1 = label.substring(0, idx);
                          line2 = label.substring(idx + 3);
                        } else if (label.includes(' — ')) {
                          const idx = label.indexOf(' — ');
                          line1 = label.substring(0, idx);
                          line2 = label.substring(idx + 3);
                        } else if (label.length > 14) {
                          const mid = Math.floor(label.length / 2);
                          const spaceIdx = label.lastIndexOf(' ', mid + 4);
                          if (spaceIdx > 0) { line1 = label.substring(0, spaceIdx); line2 = label.substring(spaceIdx + 1); }
                        }
                        const fw = p.highlight ? '700' : '500';
                        const baseY = 370;
                        return (
                          <>
                            <text x={x} y={baseY} text-anchor="middle" font-size="11" fill="var(--color-nordic)" font-family="Commissioner, sans-serif" font-weight={fw}>{line1}</text>
                            {line2 && <text x={x} y={baseY + 14} text-anchor="middle" font-size="11" fill="var(--color-nordic)" font-family="Commissioner, sans-serif" font-weight={fw}>{line2}</text>}
                            <text x={x} y={baseY + (line2 ? 28 : 14)} text-anchor="middle" font-size="10" fill="rgba(4,51,65,0.5)" font-family="Commissioner, sans-serif">{p.elevation}m</text>
                          </>
                        );
                      })()}
                    </g>
                  );
                });
              }

              return (
                <>
                  {/* fills */}
                  <path class="svg-path-1day" d={makePath(pts1day, true)} fill="url(#elevationGradient)" opacity="0.25" />
                  {pts2d1n.length > 0 && <path class="svg-path-2d1n" d={makePath(pts2d1n, true)} fill="url(#elevationGradient)" opacity="0.25" />}
                  {pts3d2n.length > 0 && <path class="svg-path-3d2n" d={makePath(pts3d2n, true)} fill="url(#elevationGradient)" opacity="0.25" />}
                  {/* lines */}
                  <path class="svg-path-1day" d={makePath(pts1day, false)} fill="none" stroke="var(--color-java)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
                  {pts2d1n.length > 0 && <path class="svg-path-2d1n" d={makePath(pts2d1n, false)} fill="none" stroke="var(--color-java)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />}
                  {pts3d2n.length > 0 && <path class="svg-path-3d2n" d={makePath(pts3d2n, false)} fill="none" stroke="var(--color-java)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />}
                  {/* dots */}
                  {renderDots(pts1day, 'svg-path-1day', step1day)}
                  {pts2d1n.length > 0 && renderDots(pts2d1n, 'svg-path-2d1n', step2d1n)}
                  {pts3d2n.length > 0 && renderDots(pts3d2n, 'svg-path-3d2n', step3d2n)}
                </>
              );
            })()}

            {/* X-axis baseline */}
            <line x1="60" y1="340" x2="1160" y2="340" stroke="var(--color-nordic)" stroke-width="1.5" opacity="0.3" />
          </svg>
        </div>
      ) : (
        <div class="td-timeline__placeholder">
          <strong>Timeline data pending.</strong>
          <p>Elevation profile for {tour.name} will be added once the route is finalized.</p>
        </div>
      )}
      {activityCards && activityCards.length > 0 && (
        <div class="td-timeline__cards">
          {activityCards.map((c: {badges?: string[]; badge?: string; badgeLabel?: string; time: string; title: string; desc: string; highlight: boolean; durationOnly?: string}) => (
            <div
              class={`td-timeline__act-card${c.highlight ? ' is-highlight' : ''}${c.durationOnly === '1day' ? ' is-1day-only' : ''}${c.durationOnly === '2d1n' ? ' is-2d1n-only' : ''}${c.durationOnly === '3d2n' ? ' is-3d2n-only' : ''}`}
              data-duration={c.durationOnly || 'all'}
            >
              <div class="td-timeline__act-badges">
                {(c.badges || (c.badgeLabel ? [c.badgeLabel] : [])).map((b: string) => (
                  <span class={`td-timeline__act-badge td-timeline__act-badge--${b.toLowerCase()}`}>{b}</span>
                ))}
              </div>
              <div class={`td-timeline__act-time${c.highlight ? ' is-highlight' : ''}`}>{c.time}</div>
              <div class="td-timeline__act-title">{c.title}</div>
              <p class="td-timeline__act-desc">{c.desc}</p>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>


  <!-- ═══ S7 · b-welcome (Welcome pack) ════════════════════════ -->
  <section class="td-welcome">
    <div class="td-welcome__inner">
      <p class="section-label">Your welcome pack</p>
      <h2 class="td-welcome__heading">{welcomePack?.subheading || "Everything in your bag has a reason."}</h2>
      <p class="td-welcome__intro">{welcomePack?.intro || "On the road, your guide hands you a Morning Vietnam pack. Not merch. Each item was chosen for what the day asks of you."}</p>
      <div class="td-welcome__grid">
        {(welcomePack?.items || []).map((item: {icon: string; name: string; why: string}) => (
          <div class="td-welcome__card">
            <div class="td-welcome__icon">{item.icon}</div>
            <div class="td-welcome__name">{item.name}</div>
            <div class="td-welcome__why">{item.why}</div>
          </div>
        ))}
        <div class="td-welcome__card-img">
          <img src="https://images.unsplash.com/photo-1528127269322-539801943592?w=600&q=80" alt="Welcome pack" />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ S6 · b-unlock (the secret game) ═══════════════════════ -->
  {unlock && (
    <section class="td-unlock">
      <div class="td-unlock__inner">
        <p class="section-label">{unlock.sectionLabel}</p>
        <h2 class="td-unlock__heading">{unlock.headline}</h2>
        <p class="td-unlock__intro">{unlock.intro}</p>

        <div class="td-unlock__cards">
          {(unlock.steps || []).map((step: {num: number; title: string; desc: string}) => (
            <div class="td-unlock__card">
              <div class="td-unlock__num">{step.num}</div>
              <h3 class="td-unlock__card-title">{step.title}</h3>
              <p class="td-unlock__card-desc">{step.desc}</p>
            </div>
          ))}
        </div>

        {unlock.note && (
          <div class="td-unlock__note">
            <p>{unlock.note}</p>
          </div>
        )}

        {unlock.teaser && (
          <p class="td-unlock__teaser">{unlock.teaser}</p>
        )}
      </div>
    </section>
  )}

  <!-- ═══ S9 · b-season (When to go) ═══════════════════════════ -->
  <section class="td-season">
    <div class="td-season__inner">
      <p class="section-label">When to go</p>
      <h2 class="td-season__heading">By season.</h2>
      <p class="td-season__intro">{season?.intro || "There's no wrong time. But here's what each season gives you."}</p>

      <div class="td-season__bar">
        {(season?.months || []).map((m: {name: string; level: string}) => (
          <div class={`td-season__month td-season__month--${m.level}`}>
            <span class="td-season__month-label">{m.name}</span>
            <span class="td-season__month-mark">{
              m.level === 'best' ? '★' :
              m.level === 'good' ? '◎' :
