  /* ── Duration show/hide ─────────────────────────── */
  /* Dùng :global() để bypass Astro scoped CSS */

  /* Mặc định ẩn 2D1N elements, hiện 1day elements */
  :global(.is-2d1n-only) {
    display: none !important;
  }
  :global(g.is-2d1n-only) {
    display: unset !important;
    visibility: hidden;
    pointer-events: none;
  }

  /* is-1day-only: visible by default, hidden in 2d1n and 3d2n modes */
  :global(g.is-1day-only) {
    display: unset !important;
    visibility: visible;
    pointer-events: auto;
  }
  :global(body.dur-2d1n .is-1day-only) { display: none !important; }
  :global(body.dur-2d1n g.is-1day-only) { visibility: hidden; pointer-events: none; }
  :global(body.dur-3d2n .is-1day-only) { display: none !important; }
  :global(body.dur-3d2n g.is-1day-only) { visibility: hidden; pointer-events: none; }

  /* is-3d2n-only: hidden by default, shown in 3d2n mode */
  :global(.is-3d2n-only) { display: none !important; }
  :global(g.is-3d2n-only) { display: unset !important; visibility: hidden; pointer-events: none; }
  :global(body.dur-3d2n .is-3d2n-only) { display: block !important; }
  :global(body.dur-3d2n g.is-3d2n-only) { display: unset !important; visibility: visible; pointer-events: auto; }
  :global(body.dur-3d2n .is-2d1n-only) { display: none !important; }
  :global(body.dur-3d2n g.is-2d1n-only) { visibility: hidden; pointer-events: none; }

  /* SVG paths: 1day visible by default, 2d1n + 3d2n hidden */
  :global(.svg-path-2d1n) { display: none; }
  :global(.svg-path-3d2n) { display: none; }
  :global(.svg-path-1day) { display: unset; }
  :global(body.dur-2d1n .svg-path-1day) { display: none; }
  :global(body.dur-2d1n .svg-path-2d1n) { display: unset; }
  :global(body.dur-3d2n .svg-path-1day) { display: none; }
  :global(body.dur-3d2n .svg-path-2d1n) { display: none; }
  :global(body.dur-3d2n .svg-path-3d2n) { display: unset; }

  /* Khi body.dur-2d1n → hiện 2D1N, ẩn 1day */
  :global(body.dur-2d1n .is-2d1n-only) {
    display: block !important;
  }
  :global(body.dur-2d1n g.is-2d1n-only) {
    display: unset !important;
    visibility: visible;
    pointer-events: auto;
  }

