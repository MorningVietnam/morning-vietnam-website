    line-height: 1.6;
  }


  /* ── S4 td-timeline ──────────────────────────────── */
  .td-timeline {
    background: var(--color-light-cyan);
    padding: 120px 0;
  }

  .td-timeline__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 48px;
  }

  .td-timeline__label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-java);
    margin-bottom: 16px;
  }

  .td-timeline__heading {
    font-family: var(--font-heading);
    font-size: clamp(32px, 4.5vw, 56px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-nordic);
    margin-bottom: 12px;
  }

  .td-timeline__sub {
    font-size: 16px;
    line-height: 1.65;
    color: var(--color-nordic);
    opacity: 0.7;
    margin-bottom: 48px;
    max-width: 560px;
  }

  .td-timeline__chart-wrap {
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .td-timeline__svg {
    display: block;
  }

  .td-timeline__placeholder {
    background: rgba(29, 160, 160, 0.06);
    border: 2px dashed var(--color-java);
    border-radius: 16px;
    padding: 64px 40px;
    text-align: center;
    color: var(--color-nordic);
    opacity: 0.6;
    font-size: 15px;
    line-height: 1.6;
  }

  /* ── td-timeline activity cards ─────────────────── */
  .td-timeline__cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
    margin-top: 40px;
  }

  .td-timeline__act-card {
    background: white;
    border-radius: 12px;
    padding: 22px 20px;
    border-left: 4px solid var(--color-java);
    box-shadow: 0 2px 12px rgba(4,51,65,0.06);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .td-timeline__act-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(4,51,65,0.10);
  }

  .td-timeline__act-card.is-highlight { border-left-color: var(--color-sorbus); }

  .td-timeline__act-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 10px;
  }

  .td-timeline__act-badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 12px;
  }

  /* Badge color per type */
  .td-timeline__act-badge--history       { background: var(--color-white-nectar); color: #413d04; }
  .td-timeline__act-badge--meal          { background: #fde8d8; color: #8b3a10; }
  .td-timeline__act-badge--challenge     { background: #e8f5e9; color: #2e7d32; }
  .td-timeline__act-badge--hiking        { background: var(--color-light-cyan); color: var(--color-nordic); }
  .td-timeline__act-badge--accommodation { background: #ede7f6; color: #4527a0; }
  /* Fallbacks for old data */
  .td-timeline__act-badge--trek    { background: var(--color-light-cyan); color: var(--color-nordic); }
  .td-timeline__act-badge--food    { background: #fde8d8; color: #8b3a10; }
  .td-timeline__act-badge--culture { background: var(--color-white-nectar); color: #413d04; }
  .td-timeline__act-badge--free    { background: #e8f5e9; color: #2e7d32; }

  .td-timeline__act-time {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-java);
    margin-bottom: 6px;
  }

  .td-timeline__act-time.is-highlight { color: var(--color-sorbus); }

  .td-timeline__act-title {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 700;
    color: var(--color-nordic);
    line-height: 1.3;
    margin-bottom: 8px;
  }

  .td-timeline__act-desc {
    font-size: 13px;
    line-height: 1.6;
    color: var(--color-nordic);
    opacity: 0.7;
  }

  /* ── S5 td-audience ──────────────────────────────── */
  .td-audience {
    background: var(--color-light-cyan);
    padding: 120px 0;
  }

  .td-audience__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 48px;
  }

  .td-audience__label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-java);
    margin-bottom: 16px;
  }

  .td-audience__heading {
    font-family: var(--font-heading);
    font-size: clamp(32px, 4.5vw, 56px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-nordic);
    margin-bottom: 56px;
  }

  .td-audience__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .td-audience__card {
    background: white;
    border-radius: 20px;
    padding: 36px 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .td-audience__card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(4, 51, 65, 0.12);
  }

  .td-audience__icon {
    font-size: 36px;
    line-height: 1;
    margin-bottom: 4px;
  }

  .td-audience__card-title {
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 700;
    color: var(--color-nordic);
    line-height: 1.2;
  }

  .td-audience__card-desc {
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-nordic);
    opacity: 0.75;
  }

  /* ── Responsive ─────────────────────────────────── */
  @media (max-width: 960px) {
    .td-product__inner         { grid-template-columns: 1fr; }
    .td-product__gallery       { min-height: 480px; padding: 32px 24px 24px; }
    .td-product__panel         { padding: 40px 24px; }
    .td-overview__inner        { grid-template-columns: 1fr; gap: 48px; padding: 0 24px; }
    .td-overview               { padding: 80px 0 60px; }
    .td-timeline__inner        { padding: 0 24px; }
    .td-timeline               { padding: 80px 0; }
    .td-audience__inner        { padding: 0 24px; }
    .td-audience               { padding: 80px 0; }
    .td-audience__grid         { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 480px) {
    .td-product__thumb { width: 60px; height: 60px; }
    .td-product__heading { font-size: 36px; }
    .td-product__price   { font-size: 28px; }
    .td-audience__grid { grid-template-columns: 1fr; }
    .td-tripinfo__grid { grid-template-columns: 1fr; }
    :global(.td-tripinfo__icon-wrap) { width: 36px; height: 36px; }
    :global(.td-tripinfo__icon-wrap i) { font-size: 17px; }
    .td-duration__tab  { font-size: 13px; padding: 9px 12px; }
  }

  /* ── S7 td-welcome ─────────────────────────────── */
  .td-welcome {
    background: var(--color-light-cyan);
    padding: 120px 0;
  }

  .td-welcome__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 48px;
  }

  .td-welcome__heading {
    font-family: var(--font-heading);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-nordic);
    margin: 12px 0 20px;
  }

  .td-welcome__intro {
    font-size: 17px;
    line-height: 1.7;
    color: var(--color-nordic);
    opacity: 0.75;
    max-width: 640px;
    margin-bottom: 56px;
  }

  .td-welcome__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 20px;
  }

  .td-welcome__card {
    background: var(--color-white-nectar);
    border-radius: 16px;
    padding: 24px 20px;
    text-align: center;
    border-top: 4px solid #a08f1d;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .td-welcome__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(4,51,65,0.10);
  }

  .td-welcome__icon { font-size: 36px; margin-bottom: 12px; }

  .td-welcome__name {
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 700;
    color: #413d04;
    margin-bottom: 8px;
  }

  .td-welcome__why {
    font-size: 12px;
    line-height: 1.55;
    color: rgba(65,61,4,0.7);
  }

  .td-welcome__card-img {
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 3 / 4;
  }

  .td-welcome__card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 768px) {
    .td-welcome__inner { padding: 0 24px; }
    .td-welcome__grid  { grid-template-columns: repeat(2, 1fr); }
    .td-welcome        { padding: 80px 0; }
  }

  /* ── S6 td-unlock ──────────────────────────────── */
  .td-unlock {
    background: var(--color-nordic);
    padding: 120px 0;
  }

  .td-unlock__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 48px;
  }

  .td-unlock .section-label { color: var(--color-sorbus); }

  .td-unlock__heading {
    font-family: var(--font-heading);
    font-size: clamp(40px, 5.5vw, 72px);
    font-weight: 700;
    line-height: 1.0;
    letter-spacing: -0.025em;
    color: var(--color-riptide);
    margin: 12px 0 20px;
  }

  .td-unlock__intro {
    font-size: 17px;
    line-height: 1.7;
    color: rgba(217,247,245,0.78);
    max-width: 640px;
    margin-bottom: 56px;
  }

  .td-unlock__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 32px;
  }

  .td-unlock__card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(217,247,245,0.14);
    border-radius: 16px;
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .td-unlock__num {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-sorbus);
    color: white;
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .td-unlock__card-title {
    font-family: var(--font-heading);
    font-size: 19px;
    font-weight: 700;
    color: var(--color-riptide);
    line-height: 1.2;
  }

  .td-unlock__card-desc {
    font-size: 14px;
    line-height: 1.65;
    color: rgba(217,247,245,0.72);
  }

  .td-unlock__note {
    background: rgba(255,255,255,0.05);
    border-left: 3px solid var(--color-sorbus);
    border-radius: 0 12px 12px 0;
    padding: 20px 24px;
    margin-bottom: 28px;
  }

  .td-unlock__note p {
    font-size: 14px;
    line-height: 1.65;
    color: rgba(217,247,245,0.7);
    font-style: italic;
  }

  .td-unlock__teaser {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 600;
    color: rgba(217,247,245,0.45);
    letter-spacing: 0.02em;
  }

  @media (max-width: 900px) {
    .td-unlock__cards { grid-template-columns: 1fr; }
  }

  @media (max-width: 768px) {
    .td-unlock        { padding: 80px 0; }
    .td-unlock__inner { padding: 0 24px; }
  }

  /* ── S9 td-season ───────────────────────────────── */
  .td-season {
    background: var(--color-light-cyan);
    padding: 120px 0;
  }

  .td-season__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 48px;
  }

  .td-season__heading {
    font-family: var(--font-heading);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-nordic);
    margin: 12px 0 16px;
  }

  .td-season__intro {
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-nordic);
    opacity: 0.75;
    margin-bottom: 40px;
  }

  .td-season__bar {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 6px;
    margin-bottom: 24px;
  }

  .td-season__month {
    padding: 16px 4px;
    border-radius: 8px;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 18px;
  }

  .td-season__month-label {
    font-family: var(--font-heading);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
  }

  .td-season__month--best { background: var(--color-java);    color: white; }
  .td-season__month--good { background: var(--color-riptide); color: var(--color-nordic); }
  .td-season__month--wet  { background: rgba(4,51,65,0.12);   color: rgba(4,51,65,0.55); }

  .td-season__legend {
    display: flex;
    gap: 28px;
    font-size: 13px;
    color: var(--color-nordic);
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  .td-season__dot {
    width: 12px;
    height: 12px;
    border-radius: 3px;
    display: inline-block;
    margin-right: 8px;
    vertical-align: middle;
  }

  .td-season__dot--best { background: var(--color-java); }
  .td-season__dot--good { background: var(--color-riptide); }
  .td-season__dot--wet  { background: rgba(4,51,65,0.25); }

  .td-season__notes {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .td-season__note {
    background: white;
    border-radius: 12px;
    padding: 20px 24px;
    border-left: 4px solid var(--color-java);
  }

  .td-season__note--wet { border-left-color: #4a90d9; }

  .td-season__note h4 {
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 700;
    color: var(--color-nordic);
    margin-bottom: 8px;
  }

  .td-season__note p {
    font-size: 13px;
    line-height: 1.65;
    color: var(--color-nordic);
    opacity: 0.75;
  }

  @media (max-width: 960px) {
    .td-season__inner { padding: 0 24px; }
    .td-season__bar   { grid-template-columns: repeat(6, 1fr); }
    .td-season__notes { grid-template-columns: 1fr; }
    .td-season        { padding: 80px 0; }
  }

  /* ── S7 td-reviews ──────────────────────────────── */
  .td-reviews { background: var(--color-light-cyan); padding: 120px 0; }

  .td-reviews__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 48px;
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 64px;
  }

  .td-reviews__rating {
    font-family: var(--font-heading);
    font-size: clamp(72px, 9vw, 128px);
    font-weight: 700;
    color: var(--color-nordic);
    line-height: 1;
    margin: 16px 0 8px;
  }

  .td-reviews__rating-unit { font-size: 0.4em; opacity: 0.4; font-weight: 400; }
  .td-reviews__based { font-size: 14px; color: var(--color-nordic); opacity: 0.6; margin-bottom: 32px; }

  .td-reviews__breakdown { display: flex; flex-direction: column; gap: 8px; }

  .td-reviews__row {
    display: grid;
    grid-template-columns: 32px 1fr 32px;
    gap: 12px;
    align-items: center;
    font-size: 13px;
    color: var(--color-nordic);
  }

  .td-reviews__bar { height: 6px; background: var(--color-light-cyan); border-radius: 3px; overflow: hidden; }
  .td-reviews__bar-fill { height: 100%; background: var(--color-java); }

  .td-reviews__placeholder-note {
    margin-top: 24px;
    font-size: 12px;
    color: var(--color-sorbus);
    opacity: 0.7;
    font-style: italic;
  }

  .td-reviews__right { display: flex; flex-direction: column; gap: 32px; }

  .td-review {
    border-bottom: 1px solid rgba(4,51,65,0.1);
    padding-bottom: 32px;
  }

  .td-review:last-child { border-bottom: none; }
  .td-review__rating { font-size: 14px; letter-spacing: 0.16em; color: var(--color-sorbus); margin-bottom: 12px; }
  .td-review__quote { font-size: 17px; line-height: 1.65; color: var(--color-nordic); margin-bottom: 14px; }
  .td-review__author { font-size: 13px; color: var(--color-nordic); opacity: 0.7; }
  .td-review__author em { opacity: 0.5; }

  /* ── S8 td-cta ──────────────────────────────────── */
  .td-cta {
    position: relative;
    min-height: 70vh;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .td-cta__image { position: absolute; inset: 0; z-index: 1; }
  .td-cta__image img { width: 100%; height: 100%; object-fit: cover; }

  .td-cta__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(to right, rgba(4,51,65,0.85) 0%, rgba(4,51,65,0.45) 70%, transparent 100%);
  }

  .td-cta__content {
    position: relative;
    z-index: 3;
    max-width: 640px;
    margin-left: max(48px, calc((100vw - var(--max-width)) / 2 + 48px));
    padding: 80px 24px;
    color: white;
  }

  .td-cta__quote {
    font-family: var(--font-heading);
    font-size: clamp(48px, 7vw, 96px);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.025em;
    margin-bottom: 24px;
  }

  .td-cta__sub {
    font-size: 18px;
    line-height: 1.6;
    opacity: 0.85;
    margin-bottom: 36px;
    max-width: 460px;
  }

  @media (max-width: 960px) {
    .td-unlock__content { padding: 64px 24px; margin: 0; }
    .td-reviews__inner  { grid-template-columns: 1fr; gap: 48px; padding: 0 24px; }
    .td-cta__content    { margin-left: 0; padding: 64px 24px; }
  }

  /* ── S9 td-faq ──────────────────────────────────── */
  .td-faq { background: var(--color-white-nectar); padding: 120px 0; }

  .td-faq__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 48px;
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 80px;
    align-items: start;
  }

  .td-faq__heading {
    font-family: var(--font-heading);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-nordic);
    margin: 12px 0 16px;
  }

  .td-faq__sub { font-size: 15px; color: var(--color-nordic); opacity: 0.7; }
  .td-faq__sub a { color: var(--color-java); font-weight: 600; text-decoration: underline; }

  .td-faq__item {
    border-bottom: 1px solid rgba(4,51,65,0.15);
    padding: 24px 0;
  }

  .td-faq__item:first-child { border-top: 1px solid rgba(4,51,65,0.15); }

  .td-faq__item summary {
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 600;
    color: var(--color-nordic);
    cursor: pointer;
    list-style: none;
    position: relative;
    padding-right: 32px;
  }

  .td-faq__item summary::-webkit-details-marker { display: none; }

  .td-faq__item summary::after {
    content: '+';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    font-size: 24px;
    color: var(--color-java);
    transition: transform 0.2s ease;
  }

  .td-faq__item[open] summary::after { content: '−'; }

  .td-faq__answer {
    margin-top: 12px;
    font-size: 15px;
    line-height: 1.75;
    color: var(--color-nordic);
    opacity: 0.8;
  }

  /* ── S10 td-related ─────────────────────────────── */
  .td-related { background: var(--color-light-cyan); padding: 120px 0; }

  .td-related__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 48px;
  }

  .td-related__heading {
    font-family: var(--font-heading);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-nordic);
    margin: 12px 0 56px;
  }

  .td-related__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .td-related__card {
    display: flex;
    flex-direction: column;
    gap: 20px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.4s var(--ease-smooth, ease);
  }

  .td-related__card:hover { transform: translateY(-6px); }

  .td-related__card-image {
    aspect-ratio: 4/3;
    border-radius: 16px;
    overflow: hidden;
  }

  .td-related__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-smooth, ease);
  }

  .td-related__card:hover .td-related__card-image img { transform: scale(1.06); }

  .td-related__card-body { display: flex; flex-direction: column; gap: 8px; }

  .td-related__card-region {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-java);
  }

  .td-related__card-name {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 700;
    color: var(--color-nordic);
    line-height: 1.2;
  }

  .td-related__card-tagline {
    font-size: 14px;
    color: var(--color-nordic);
    opacity: 0.65;
    line-height: 1.55;
  }

  .td-related__card-link {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-sorbus);
    margin-top: 8px;
  }

  @media (max-width: 960px) {
    .td-faq__inner     { grid-template-columns: 1fr; gap: 48px; padding: 0 24px; }
    .td-related__inner { padding: 0 24px; }
    .td-related__grid  { grid-template-columns: 1fr; gap: 32px; }
    .td-faq            { padding: 80px 0; }
    .td-related        { padding: 80px 0; }
  }
</style>

<script>
  (() => {
    const mainImg = document.getElementById('td-main-img') as HTMLImageElement | null;
    const thumbs  = document.querySelectorAll<HTMLButtonElement>('.td-product__thumb');
    const prevBtn = document.getElementById('td-prev') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('td-next') as HTMLButtonElement | null;
    const gallery = document.querySelector('.td-product__gallery') as HTMLElement | null;

    if (!mainImg || thumbs.length === 0) return;

    let current = 0;
    let timer: ReturnType<typeof setInterval> | null = null;

    function goTo(idx: number) {
      current = (idx + thumbs.length) % thumbs.length;
      const t = thumbs[current];
      mainImg!.style.opacity = '0';
      setTimeout(() => {
        mainImg!.src = t.dataset.src ?? '';
        mainImg!.alt = t.dataset.alt ?? '';
        mainImg!.style.opacity = '1';
      }, 200);
      thumbs.forEach(x => x.classList.remove('active'));
      t.classList.add('active');
    }

    function startTimer() {
      timer = setInterval(() => goTo(current + 1), 3000);
    }

    function stopTimer() {
      if (timer) { clearInterval(timer); timer = null; }
    }

    function resetTimer() { stopTimer(); startTimer(); }

    // Thumb clicks
    thumbs.forEach((t, i) => {
      t.addEventListener('click', () => { goTo(i); resetTimer(); });
    });

    // Arrow buttons
    prevBtn?.addEventListener('click', () => { goTo(current - 1); resetTimer(); });
    nextBtn?.addEventListener('click', () => { goTo(current + 1); resetTimer(); });

    // Pause on hover, resume on leave
    gallery?.addEventListener('mouseenter', stopTimer);
    gallery?.addEventListener('mouseleave', startTimer);

    if (thumbs.length > 1) startTimer();
  })();

  /* ── Duration switcher ─────────────────────────────── */
  (() => {
    const panel = document.getElementById('td-product-panel');
    if (!panel) return;

    // Tag elements using data-duration attribute from template
    document.querySelectorAll<HTMLElement>('.td-timeline__act-card[data-duration], .td-timeline__point[data-duration]').forEach(el => {
      const dur = el.dataset.duration;
      if (dur && dur !== 'all') el.classList.add(`is-${dur}-only`);
    });

    const rawOptions = panel.dataset.durationOptions;
    if (!rawOptions) return;

    const durationOptions = JSON.parse(rawOptions);

    const tabs = document.querySelectorAll<HTMLButtonElement>('.td-duration__tab');
    const priceAmountEl = document.getElementById('td-price-amount');
    const taglineEl = document.getElementById('td-tagline-display');
    const ctaBtn = document.getElementById('td-cta-btn') as HTMLAnchorElement | null;
    const ctaNote = document.getElementById('td-cta-note');

    function switchDuration(id: string) {
      const opt = durationOptions.find((o: any) => o.id === id);
      if (!opt) return;

      // 1. Active tab
      tabs.forEach(t => t.classList.toggle('is-active', t.dataset.duration === id));

      // 2. Price
      const priceDisplay = document.getElementById('td-price-display');
      if (opt.price != null) {
        if (priceAmountEl) priceAmountEl.textContent = `$${opt.price}`;
        if (priceDisplay) priceDisplay.style.display = '';
      } else {
        if (priceDisplay) priceDisplay.style.display = 'none';
      }

      // 3. Tagline
      if (taglineEl) taglineEl.textContent = opt.tagline;

      // 4. CTA
      if (ctaBtn) {
        ctaBtn.href = `https://wa.me/84961836611?text=${encodeURIComponent(opt.waText)}`;
        ctaBtn.textContent = opt.ctaLabel;
      }
      if (ctaNote) ctaNote.textContent = opt.ctaNote;

      // 5. Trip Info cards
      const tripSection = document.getElementById('td-tripinfo-section');
      if (tripSection && tripSection.dataset.tripInfo) {
        const tripData = JSON.parse(tripSection.dataset.tripInfo);
        const items = tripData[id] || tripData['default'] || [];
        const grid = document.getElementById('td-tripinfo-grid');
        if (grid && items.length) {
          grid.innerHTML = items.map((item: any) => `
            <div class="td-tripinfo__card">
              <div class="td-tripinfo__icon-wrap">
                <i class="ti ti-${item.icon}" aria-hidden="true"></i>
              </div>
              <div>
                <p class="td-tripinfo__label">${item.label}</p>
                <p class="td-tripinfo__value">${item.value}</p>
              </div>
            </div>
          `).join('');
        }
      }

      // 6. Pitch swap
      const pitchSection = document.getElementById('td-pitch-section');
      if (pitchSection && pitchSection.dataset.pitch) {
        const pitchData = JSON.parse(pitchSection.dataset.pitch);
        if (pitchData[id]) {
          const headlineEl = document.getElementById('td-pitch-headline');
          const bulletList = document.getElementById('td-pitch-bullets');
          const closingEl  = document.getElementById('td-pitch-closing');
          if (headlineEl) headlineEl.textContent = pitchData[id].headline || '';
          if (bulletList) bulletList.innerHTML = (pitchData[id].bullets || []).map((b: string) => `<li>${b}</li>`).join('');
          if (closingEl)  closingEl.textContent  = pitchData[id].closingLine || '';
        }
      }

      // 7. ValueAnchor swap
      const valueSection = document.getElementById('td-value-section');
      if (valueSection && valueSection.dataset.valueAnchor) {
        const valueData = JSON.parse(valueSection.dataset.valueAnchor);
        if (valueData[id]) {
          const headlineEl = document.getElementById('td-value-headline');
          const bodyEl     = document.getElementById('td-value-paragraphs');
          if (headlineEl) headlineEl.textContent = valueData[id].headline || '';
          if (bodyEl)     bodyEl.innerHTML = (valueData[id].paragraphs || []).map((p: string) => `<p>${p}</p>`).join('');
        }
      }

      // 8. Toggle body class — CSS handles show/hide of duration-specific elements
      document.body.classList.remove('dur-2d1n', 'dur-3d2n');
      if (id === '2d1n') document.body.classList.add('dur-2d1n');
      if (id === '3d2n') document.body.classList.add('dur-3d2n');
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const id = tab.dataset.duration;
        if (id) switchDuration(id);
      });
    });
  })();
</script>
